#!/usr/bin/expect -f
# MUD Systematic Test with Expect

set timeout 3

proc test_server {port char_name} {
    spawn nc localhost $port
    expect "무림존함"
    send "무명객\r"
    expect "보기"
    send "보기\r"
    expect {
        "체력" { puts "✓ 보기: Shows room with stats" }
        timeout { puts "✗ 보기: Timeout" }
    }
    expect "보기"
    
    send "인벤토리\r"
    expect {
        "소지품" { puts "✓ 인벤토리: Shows inventory" }
        timeout { puts "✗ 인벤토리: No response" }
    }
    
    send "무공\r"
    expect {
        "무공" { puts "✓ 무공: Shows skills" }
        timeout { puts "✗ 무공: No response" }
    }
    
    send "비전\r"
    expect {
        "비전" { puts "✓ 비전: Shows vision" }
        timeout { puts "✗ 비전: No response" }
    }
    
    send "상태\r"
    expect {
        "체력" { puts "✓ 상태: Shows status" }
        timeout { puts "✗ 상태: No response" }
    }
    
    send "8\r"
    expect {
        "보기" { puts "✓ 8 (북): Moved north" }
        timeout { puts "✗ 8: No response" }
    }
    
    send "보기\r"
    expect {
        "출구" { puts "✓ 보기 after move: Shows new room" }
        timeout { puts "✗ 보기 after move: No response" }
    }
    
    close
}

puts "=========================================="
puts "Testing Python MUD (port 9900)"
puts "=========================================="
test_server 9900 "테스터1"

sleep 1

puts "\n=========================================="
puts "Testing Rust MUD (port 9990)"
puts "=========================================="
test_server 9990 "테스터1"

puts "\n=========================================="
puts "Testing Python MUD (port 9900) - Char 2"
puts "=========================================="
test_server 9900 "테스터2"

sleep 1

puts "\n=========================================="
puts "Testing Rust MUD (port 9990) - Char 2"
puts "=========================================="
test_server 9990 "테스터2"

puts "\n========== TEST COMPLETE =========="
